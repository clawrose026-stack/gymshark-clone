# Gymshark Clone E-Commerce
# Environment Variables Template

# ============================================
# SUPABASE - Separate DB from other apps
# ============================================
# Create new project at https://supabase.com
# Copy URL and anon key from Project Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (server-side only, keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# STRIPE - Payment Processing
# ============================================
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ============================================
# EMAIL (Optional - for order confirmations)
# ============================================
# Using Gmail SMTP or SendGrid
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Or SendGrid
SENDGRID_API_KEY=SG.your_api_key

# ============================================
# APP CONFIG
# ============================================
VITE_APP_NAME=Gymshark Clone
VITE_APP_URL=http://localhost:5173

# ============================================
# SHIPPING (Configure rates)
# ============================================
# Free shipping threshold
FREE_SHIPPING_THRESHOLD=100

# Flat rate shipping
FLAT_SHIPPING_RATE=10

# ============================================
# TAX (Configure for your region)
# ============================================
# South Africa VAT
DEFAULT_TAX_RATE=0.15

# ============================================
# FEATURE FLAGS
# ============================================
VITE_ENABLE_REVIEWS=true
VITE_ENABLE_WISHLIST=true
VITE_ENABLE_LOYALTY=true
